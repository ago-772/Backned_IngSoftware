# ==================================================
# Software Engineering 2026 - Final Project
# Environment Variables Configuration
# ==================================================
# This file contains all environment variables for the entire project.
# Copy this file to .env and update values as needed.
#
# IMPORTANT: Never commit the .env file to version control!
# ==================================================

# --------------------------------------------------
# PostgreSQL Database Configuration
# --------------------------------------------------
# These variables are used by:
# - Docker Compose (PostgreSQL container)
# - All backend applications (Flask, Spring, NestJS)

# Database connection details (from the host: use the Docker *published* port)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=soft_eng_db
POSTGRES_USER=soft_eng_user
POSTGRES_PASSWORD=dev_password_2026

# PostgreSQL initialization arguments
POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C

# Computed database URLs (used by different frameworks)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_USERNAME=${POSTGRES_USER}
DATABASE_PASSWORD=${POSTGRES_PASSWORD}

# --------------------------------------------------
# Flask Backend Configuration
# (run CLI / server from backend/flask/final_project)
# --------------------------------------------------
FLASK_APP=main:app
FLASK_DEBUG=1
FLASK_ENV=development
FLASK_PORT=5000

# Security (sessions / signing — change in production)
FLASK_SECRET_KEY=your_super_secret_key_here_change_in_production

# --------------------------------------------------
# Spring Boot Backend Configuration
# --------------------------------------------------
# Used by backend/spring (application.properties server.port). Not FLASK_PORT / NESTJS_PORT.
# bootRun loads this file from the repo root; other launches must export SPRING_PORT or set SERVER_PORT.
SPRING_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --------------------------------------------------
# NestJS Backend Configuration
# --------------------------------------------------
NESTJS_PORT=3000
NODE_ENV=development

# --------------------------------------------------
# Frontend Configuration (Next.js dashboard in frontend/dashboard)
# --------------------------------------------------
# Base URL the browser uses to call the REST API. Match the backend you run:
#   NestJS ~ :3000, Spring Boot ~ :8080, Flask ~ :5000
NEXT_PUBLIC_API_URL=http://localhost:5000